---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoCard from '../components/VideoCard.astro';
import { configuredSocials } from '../config/site';
const videos = (await getCollection('videos')).sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const publishedVideos = videos.filter((video) => !video.data.title.startsWith('Próximo'));
---
<BaseLayout title="Videos · Mario Colli" description="Videos y contenido de Mario Colli en redes.">
  <section class="videos-page">
    <p class="eyebrow">Videos</p>
    <h1>Contenido para seguir explorando.</h1>
    {publishedVideos.length > 0 ? <div class="post-grid">{publishedVideos.map((video) => <VideoCard video={video} />)}</div> : <div class="empty-state"><p class="lede">Próximamente compartiré aquí los videos publicados. Mientras tanto, puedes seguir el proceso en mis redes.</p><div class="socials">{configuredSocials.map((social) => <a class="pill" href={social.url} target="_blank" rel="me noopener noreferrer">{social.name} <span aria-hidden="true">↗</span></a>)}</div></div>}
  </section>
</BaseLayout>
<style>.videos-page{min-height:52vh}.post-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.empty-state{max-width:56ch;padding:1.5rem 0}.socials{display:flex;flex-wrap:wrap;gap:.65rem;margin-top:1.5rem}@media(max-width:700px){.post-grid{grid-template-columns:1fr}}</style>
