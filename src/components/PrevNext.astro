---
const { previous, next } = Astro.props;
---

{(previous || next) && (
  <nav class="prev-next" aria-label="Navegación entre entradas">
    <div class="prev-slot">
      {previous && (
        <a href={`/posts/${previous.id}/`}>
          <span class="nav-arrow" aria-hidden="true">←</span>
          <span class="nav-title">{previous.data.title}</span>
        </a>
      )}
    </div>
    <div class="prev-slot next-slot">
      {next && (
        <a href={`/posts/${next.id}/`}>
          <span class="nav-title">{next.data.title}</span>
          <span class="nav-arrow" aria-hidden="true">→</span>
        </a>
      )}
    </div>
  </nav>
)}

<style>
  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 1rem;
    margin: 3rem 0;
  }

  .prev-slot {
    display: flex;
    min-width: 0;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .next-slot {
    justify-content: flex-end;
    text-align: right;
  }

  .prev-slot a {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: stretch;
    column-gap: 0.45rem;
    width: 100%;
    height: 100%;
    color: inherit;
    text-decoration: none;
    transition: color 0.18s ease, transform 0.18s ease, text-shadow 0.18s ease;
  }

  .next-slot a {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .nav-title {
    align-self: start;
    min-width: 0;
  }

  .nav-arrow {
    align-self: center;
    display: block;
    font-size: 1.2em;
    line-height: 1;
  }

  .prev-slot a:hover,
  .prev-slot a:focus-visible {
    color: var(--accent);
    text-shadow: 2px 3px 8px color-mix(in srgb, var(--accent) 28%, transparent);
    transform: translateY(-2px);
  }

  @media (max-width: 700px) {
    .prev-next {
      grid-template-columns: 1fr;
    }

    .next-slot {
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
