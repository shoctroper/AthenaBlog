---
const { title, category, image = '', showTitle = true } = Astro.props as { title: string; category: string; image?: string; showTitle?: boolean };
const colors: Record<string, string> = { Tecnología:'#C4664A', Ideas:'#26221E', Salud:'#7A8B6F', Historia:'#B98B4E', Ciencia:'#3E6B74' };
const background = colors[category] ?? colors.Ideas;
const words = title.split(/\s+/).reduce<string[]>((lines, word) => { const last = lines.at(-1) ?? ''; if ((last + ' ' + word).trim().length > 18 && lines.length < 3) lines.push(word); else lines[lines.length - 1] = `${last} ${word}`.trim(); return lines; }, ['']);
---
{image ? <img class="cover-image" src={image} alt="" /> : showTitle ? <svg class="cover" viewBox="0 0 1200 675" role="img" aria-label={`Portada: ${title}`} data-visual-title={title} xmlns="http://www.w3.org/2000/svg"><rect width="1200" height="675" fill={background}/><text x="80" y="85" fill="#FAF6F0" font-family="system-ui,sans-serif" font-size="24" font-weight="700" letter-spacing="5">{category.toUpperCase()}</text>{words.map((line, index) => <text x="80" y={250 + index * 105} fill="#FAF6F0" font-family="Georgia,serif" font-size="82">{line}</text>)}<text x="80" y="610" fill="#FAF6F0" font-family="system-ui,sans-serif" font-size="24" letter-spacing="3">MARIO COLLI</text></svg> : <div class="category-band" aria-label={`Categoría: ${category}`}>{category}</div>}
<style>.cover,.cover-image,.category-band{display:block;width:100%;height:100%;object-fit:cover}.category-band{display:grid;place-items:center;background:var(--cover-color,#26221E);color:#FAF6F0;font:700 1rem/1 var(--sans,system-ui,sans-serif);letter-spacing:.18em;text-transform:uppercase}</style>
