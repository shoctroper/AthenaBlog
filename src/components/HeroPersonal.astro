---
import { configuredSocials } from '../config/site';
---
<section class="hero-personal">
  <div>
    <p class="eyebrow">Ideas, tecnología y vida</p>
    <h1>Hola, soy <em>Mario</em></h1>
    <p class="lede">Exploro la intersección entre la tecnología, la fotografía y las ideas. Documento lo que aprendo, construyo y creo.</p>
    <div class="hero-socials" aria-label="Redes sociales">
      {configuredSocials.map((social) => <a href={social.url} target="_blank" rel="me noopener noreferrer">{social.name}</a>)}
    </div>
  </div>
  <img class="avatar" src="/images/mario-colli-hero.png" alt="Mario Colli en su estudio" width="1402" height="1122" />
</section>
<style>.hero-personal{display:grid;grid-template-columns:1fr 220px;gap:3rem;align-items:center;padding:2rem 0 3rem}.hero-personal h1{font-size:clamp(3rem,7vw,5.5rem);margin:.2rem 0}.hero-personal em{color:var(--accent)}.avatar{display:block;width:220px;height:280px;object-fit:cover;object-position:50% 35%;justify-self:center;border:1px solid var(--line);border-radius:18px;box-shadow:10px 10px 0 var(--panel)}.hero-socials{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem}.hero-socials a{border:1px solid var(--line);border-radius:999px;padding:.35rem .7rem;text-decoration:none;font-size:.78rem}@media(max-width:700px){.hero-personal{grid-template-columns:1fr;gap:1.5rem}.avatar{width:min(100%,360px);height:320px;order:-1;justify-self:start}}</style>
