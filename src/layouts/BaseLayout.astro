---
import { configuredSocials, site as siteConfig } from '../config/site';
interface Props { title: string; description: string; canonical?: string }
const { title, description, canonical } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'http://localhost:4321';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical ?? `${site}${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical ?? `${site}${Astro.url.pathname}`} />
    <meta property="og:image" content={`${site}/og-default.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og-default.svg`} />
    <title>{title}</title>
    <script is:inline>
      const saved = localStorage.getItem('mario-theme');
      document.documentElement.dataset.theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    </script>
    <style is:global>
      :root { --bg:#FAF6F0;--surface:#FFF;--ink:#26221E;--accent:#9A432D;--muted:#655C55;--line:#D8CCC0;--panel:#F2EAE0;--display:Georgia,serif;--sans:Inter,system-ui,sans-serif } :root[data-theme='dark']{--bg:#211d1a;--surface:#2b2622;--ink:#fcf4ec;--accent:#ffab90;--muted:#ded0c3;--line:#66594f;--panel:#302923} *{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--ink);font:17px/1.7 var(--sans)}a{color:inherit}.shell{width:min(1040px,calc(100% - 3rem));margin:auto}header{border-bottom:1px solid var(--line);padding:1.2rem 0}nav{display:flex;justify-content:space-between;align-items:center;gap:1rem}nav a{text-decoration:none}.brand{font:26px var(--display)}.descriptor,.eyebrow{font:11px var(--sans);letter-spacing:.13em;text-transform:uppercase;color:var(--muted)}.navlinks{display:flex;align-items:center;gap:1.25rem;font:11px var(--sans);letter-spacing:.1em;text-transform:uppercase}.navlinks .subscribe{background:var(--accent);color:white;padding:.7rem 1rem;border-radius:999px}button{color:var(--ink);background:transparent;border:1px solid var(--line);border-radius:999px;padding:.35rem .6rem;cursor:pointer}.mobile-menu{display:none}main{padding:3rem 0 5rem}footer{background:var(--panel);padding:1.5rem 0;color:var(--muted);font:12px var(--sans)}h1,h2,h3{font-family:var(--display);font-weight:400;line-height:1.15}.lede{color:var(--muted);max-width:56ch;font-size:1.05rem}.pill,.tag{border:1px solid var(--line);border-radius:999px;padding:.45rem .8rem;text-decoration:none;font:11px var(--sans);letter-spacing:.1em;text-transform:uppercase}.tags{display:flex;flex-wrap:wrap;gap:.5rem}.footer-grid{display:flex;justify-content:space-between;gap:1rem;align-items:center}.footer-grid a{text-decoration:none}.article-body{max-width:68ch;font:18px/1.8 var(--display)}.article-body h2{margin-top:2.5rem}.post-hero{aspect-ratio:16/9;border-radius:14px;background:radial-gradient(circle at 72% 32%,var(--accent) 0 9%,transparent 9.5%),linear-gradient(135deg,#d7c6b5,var(--panel));margin:2rem 0}.newsletter{background:var(--ink);color:var(--bg);border-radius:12px;padding:2rem;display:flex;justify-content:space-between;gap:1rem;align-items:center;margin-top:3rem}.newsletter .eyebrow{color:#ffd0bf}.newsletter a{background:var(--accent);color:white}.related{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.related a{text-decoration:none;border:1px solid var(--line);padding:1rem;border-radius:10px}@media(max-width:700px){.shell{width:min(100% - 1.5rem,1040px)}.navlinks a{display:none}.mobile-menu{display:block;position:relative}.mobile-menu summary{list-style:none;border:1px solid var(--line);border-radius:999px;padding:.48rem .7rem;font:700 11px var(--sans);letter-spacing:.08em;text-transform:uppercase;cursor:pointer}.mobile-menu summary::-webkit-details-marker{display:none}.mobile-links{position:absolute;right:0;top:calc(100% + .65rem);z-index:10;width:190px;padding:.45rem;background:var(--surface);border:1px solid var(--line);border-radius:12px;box-shadow:0 12px 30px #0002}.mobile-links a{display:block;padding:.65rem .75rem;font:12px var(--sans);letter-spacing:.06em;text-transform:uppercase}.footer-grid,.newsletter{align-items:flex-start;flex-direction:column}.related{grid-template-columns:1fr}}
      .masthead { display:grid; grid-template-columns:1.35fr .65fr; gap:3rem; align-items:end; padding:4.5rem 0 5rem; border-top:1px solid var(--line); } .masthead .lede { margin:0; } .mast-art { min-height:280px; border-radius:180px 180px 2rem 2rem; background:radial-gradient(circle at 50% 32%,var(--card) 0 12%,transparent 12.5%),radial-gradient(circle at 48% 45%,var(--warm) 0 26%,transparent 26.5%),linear-gradient(145deg,var(--accent),#2e625c); position:relative; overflow:hidden; } .mast-art::before,.mast-art::after { content:''; position:absolute; border:1px solid #fff9; border-radius:50%; } .mast-art::before { width:170%; aspect-ratio:1; left:-35%; top:18%; } .mast-art::after { width:90%; aspect-ratio:1; left:5%; top:50%; }
      .section-head { display:flex; justify-content:space-between; align-items:baseline; border-top:1px solid var(--ink); padding-top:.9rem; margin-bottom:1.4rem; } .section-head h2 { margin:0; font-size:1.15rem; font-family:var(--sans); letter-spacing:-.03em; }
      .feature-card { display:grid; grid-template-columns:.82fr 1.18fr; min-height:440px; background:var(--card); text-decoration:none; border:1px solid var(--line); transition:transform .25s ease,box-shadow .25s ease; } .feature-card:hover { transform:translateY(-5px); box-shadow:10px 12px 0 var(--accent); } .feature-art { min-height:240px; background:linear-gradient(160deg,var(--accent),#27554e); position:relative; overflow:hidden; } .feature-art::before { content:'A'; font:clamp(11rem,25vw,20rem)/1 var(--display); color:#fff2; position:absolute; right:-.05em; bottom:-.14em; } .feature-art::after { content:'01'; position:absolute; top:1.4rem; left:1.4rem; color:#fff; font:800 13px var(--sans); letter-spacing:.16em; } .feature-copy { padding:3rem; display:flex; flex-direction:column; justify-content:end; } .feature-copy h2 { font-size:clamp(2.2rem,4vw,4rem); margin:.4rem 0 1rem; max-width:12ch; } .feature-copy p { margin:.2rem 0; max-width:42ch; } .feature-arrow { margin-top:2rem; color:var(--accent); font:700 13px var(--sans); letter-spacing:.08em; text-transform:uppercase; }
      article { max-width:790px; } .article-kicker { display:grid; grid-template-columns:90px 1fr; gap:1.5rem; align-items:start; } .date-block { font:800 12px/1.1 var(--sans); color:var(--accent); border-top:3px solid var(--accent); padding-top:.5rem; letter-spacing:.08em; } .date-block strong { display:block; font-size:3rem; letter-spacing:-.12em; } article h1 { max-width:15ch; font-size:clamp(3rem,6vw,5.4rem); } .article-visual { height:235px; margin:2rem 0 2.6rem; border-radius:1.3rem; background:linear-gradient(125deg,var(--soft),transparent),radial-gradient(circle at 70% 35%,var(--warm) 0 10%,transparent 10.5%),radial-gradient(circle at 30% 70%,var(--accent) 0 22%,transparent 22.5%),var(--ink); position:relative; overflow:hidden; } .article-visual::after { content:'Trazabilidad'; position:absolute; right:1.5rem; bottom:1rem; color:#fff; font:700 11px var(--sans); letter-spacing:.17em; text-transform:uppercase; }
      article table { width:100%; border-collapse:collapse; font-size:.9rem; } article th,article td { text-align:left; vertical-align:top; padding:.55rem; border-bottom:1px solid var(--line); } pre { overflow:auto; padding:1rem; background:var(--card); border:1px solid var(--line); } .callout { margin:2rem 0; padding:1.35rem 1.5rem; background:var(--card); border:1px solid var(--line); border-radius:0 1rem 1rem 1rem; box-shadow:5px 5px 0 var(--soft); } .warning { border-left:4px solid var(--warm); }
      .social-follow { margin:5rem 0 0; padding:3rem; background:var(--ink); color:var(--bg); border-radius:2rem 2rem 0 2rem; } .social-follow .eyebrow { color:var(--accent); } .social-follow h2 { font-size:clamp(2.2rem,4vw,4rem); margin:.3rem 0 1.7rem; max-width:11ch; } .social-links { display:flex; gap:.65rem; flex-wrap:wrap; } .social-links a { border:1px solid #ffffff55; border-radius:99px; padding:.65rem .9rem; text-decoration:none; font:700 12px var(--sans); letter-spacing:.05em; text-transform:uppercase; } .social-links a:hover { background:var(--warm); border-color:var(--warm); } .social-links span { color:var(--accent); } .social-pending { max-width:52ch; color:#d5ddd6; font:15px/1.6 var(--sans); }.post-caption { margin:3rem 0; padding:1.2rem 0; border-top:1px solid var(--line); border-bottom:1px solid var(--line); font-size:1.2rem; }.footer-grid { display:grid; grid-template-columns:1.2fr 1fr auto; gap:1.5rem; align-items:center; }.footer-grid p { margin:.25rem 0 0; }.footer-grid a { color:var(--muted); text-decoration:none; }.footer-grid a:hover { color:var(--ink); }.footer-socials { display:flex; gap:.75rem; font-weight:700; }
      .welcome { padding:4rem 0 3rem; border-bottom:1px solid var(--line); }.welcome h1 { max-width:12ch; }.principles { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--line); margin:3rem 0; border:1px solid var(--line); }.principles > div { background:var(--card); padding:2rem; }.principles span { color:var(--warm); font:800 13px var(--sans); letter-spacing:.1em; }.principles h2 { margin:.6rem 0; font-size:2rem; }.principles p { color:var(--muted); }.profile { display:grid; grid-template-columns:.7fr 1.3fr; align-items:center; gap:4rem; padding:4rem 0; }.profile-art { min-height:430px; border-radius:50% 50% 1rem 1rem; background:linear-gradient(140deg,var(--warm),var(--accent)); color:#fff5; display:grid; place-items:center; font:clamp(12rem,25vw,20rem)/1 var(--display); }.profile h1,.contact h1 { max-width:11ch; }.contact { padding:5rem 0; min-height:58vh; }.contact-cta { display:inline-block; margin-top:2rem; background:var(--ink); color:var(--bg); text-decoration:none; padding:1rem 1.4rem; border-radius:99px; font:700 13px var(--sans); letter-spacing:.05em; text-transform:uppercase; }
      @media (max-width:700px) { .shell { width:min(100% - 1.5rem,1180px) } .masthead,.feature-card,.profile { grid-template-columns:1fr; } .masthead { padding:2.5rem 0 3rem; gap:2rem; } .mast-art { min-height:180px; } .feature-copy { padding:2rem; } .article-kicker { grid-template-columns:1fr; gap:.75rem; } .date-block strong { display:inline; margin-right:.5rem; } .navlinks a:not(:last-child) { display:none; } .principles,.footer-grid { grid-template-columns:1fr; } .profile { gap:2rem; } .profile-art { min-height:260px; } .social-follow { padding:2rem; } }
    </style>
  </head>
  <body>
    <header><div class="shell"><nav><div><a class="brand" href="/">{siteConfig.name}</a><div class="descriptor">{siteConfig.descriptor}</div></div><div class="navlinks"><a href="/">Blog</a><a href="/videos/">Videos</a><a href="/sobre-mi/">Sobre mí</a><a href="/contacto/">Contacto</a><a class="subscribe" href="#newsletter">Suscríbete</a><button id="theme" aria-label="Cambiar tema">◐</button><details class="mobile-menu"><summary>Menú</summary><div class="mobile-links"><a href="/">Blog</a><a href="/videos/">Videos</a><a href="/sobre-mi/">Sobre mí</a><a href="/contacto/">Contacto</a></div></details></div></nav></div></header>
    <main class="shell"><slot /></main>
    <footer><div class="shell"><div class="footer-grid"><strong class="brand">{siteConfig.name}</strong><span><a href="/sobre-mi/">Sobre mí</a> · <a href="/contacto/">Contacto</a> · <a href="/rss.xml">RSS</a></span><span class="footer-socials">{configuredSocials.map((social) => <a href={social.url} target="_blank" rel="me noopener noreferrer">{social.name}</a>)}</span></div></div></footer>
    <script is:inline>document.querySelector('#theme')?.addEventListener('click', () => { const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'; document.documentElement.dataset.theme = next; localStorage.setItem('mario-theme', next); });</script>
  </body>
</html>
