{
  "name": "athenaos-journal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/check-deks.mjs && astro check && astro build && node scripts/check-public-html.mjs && node scripts/check-card-titles.mjs && node scripts/check-social-cards.mjs",
    "generate:social": "node scripts/generate-social-cards.mjs",
    "preview": "astro preview",
